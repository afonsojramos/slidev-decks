{
  "name": "slidev-decks",
  "version": "0.1.0",
  "description": "CLI companion for managing multiple Slidev presentations",
  "type": "module",
  "bin": {
    "slidev-decks": "./dist/cli.js",
    "sd": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
