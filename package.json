    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18"
  }
