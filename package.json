{
  "name": "slidev-decks",
  "version": "0.3.0",
  "description": "CLI companion for managing multiple Slidev presentations",
  "keywords": [
    "cli",
    "multi-deck",
    "presentation",
    "slides",
    "slidev",
    "talks"
  ],
  "license": "MIT",
  "author": "Afonso Ramos",
  "repository": {
    "type": "git",
    "url": "https://github.com/afonsojramos/slidev-decks"
  },
  "bin": {
    "sd": "./dist/cli.js",
    "slidev-decks": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
